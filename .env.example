# 飞书应用凭证（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kiro CLI 超时时间（秒）
KIRO_TIMEOUT=120
# KIRO_SYNC_TIMEOUT=120
# KIRO_ASYNC_TIMEOUT=1800
# KIRO_PROGRESS_INTERVAL=300

# 指定 Kiro agent（可选，留空则使用默认 agent）
# KIRO_AGENT=my-dev-bot

# 记忆功能开关（可选，默认关闭。零额外依赖，基于 sqlite3）
# ENABLE_MEMORY=true

# 群聊中是否只响应 @机器人 的消息（可选，默认 true）
# GROUP_AT_ONLY=true

# === Webhook 告警接收配置 ===
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8080
# WEBHOOK_HOST=127.0.0.1          # 127.0.0.1=仅本机, 0.0.0.0=全网卡, 192.168.x.x=内网
# WEBHOOK_TOKEN=change-me-secret

# === 主动告警推送 ===
# ALERT_NOTIFY_USER_ID=ou_xxxxxxxxxxxxxxxx
# ALERT_AUTO_ANALYZE_SEVERITY=high,critical
# ALERT_ANALYZE_TIMEOUT=300

# === 微信 iLink（新增）===
WEIXIN_BOT_TOKEN=                      # 可选；留空则启动时扫码获取
# WEIXIN_TOKEN_FILE=~/.kiro/weixin_token.json

# === 告警推送（改造）===
# 旧：ALERT_NOTIFY_USER_ID=ou_xxx
# 新：支持多目标，逗号分隔
ALERT_NOTIFY_TARGETS=feishu:ou_xxxxxxxx,weixin:wxid_xxxxxxxx@im.wechat

# === Dashboard Web Panel ===
# DASHBOARD_TOKEN=change-me-strong-secret
# === Prometheus 配置（Resource Dashboard 预留）===
# PROMETHEUS_URL=http://localhost:9090
